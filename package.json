{
  "name": "logflow",
  "displayName": "LogFlow",
  "description": "Context-aware log injection using AST parsing",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "logflow.insertLog",
        "title": "LogFlow: Insert Context-Aware Log"
      }
    ],
    "keybindings": [
      {
        "command": "logflow.insertLog",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "@types/babel__traverse": "^7.20.1",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0"
  }
}
