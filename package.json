{
  "name": "logflow",
  "displayName": "LogFlow",
  "description": "Context-aware log injection using AST parsing",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "logflow.insertLog",
        "title": "LogFlow: Insert Context-Aware Log"
      }
    ],
    "keybindings": [
      {
        "command": "logflow.insertLog",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "LogFlow",
      "properties": {
        "logflow.clientEmoji": {
          "type": "string",
          "default": "🎨",
          "description": "Emoji prefix to use for Client Components"
        },
        "logflow.serverEmoji": {
          "type": "string",
          "default": "🎒",
          "description": "Emoji prefix to use for Server Components"
        },
        "logflow.clientColor": {
          "type": "string",
          "default": "#00adb5",
          "description": "Hex color code to natively style Context-Aware output in browser DevTools"
        },
        "logflow.includeLineNumbers": {
          "type": "boolean",
          "default": false,
          "description": "Dynamically append the active line number directly into the injected log signature"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "@types/babel__traverse": "^7.20.1",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0"
  }
}
