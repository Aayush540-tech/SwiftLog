{
  "name": "swiftlog",
  "displayName": "SwiftLog",
  "publisher": "Aayush540-tech",
  "description": "Context-aware log injection using AST parsing",
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aayush540-tech/SwiftLog"
  },
  "icon": "images/SwiftLog.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "swiftlog.insertLog",
        "title": "SwiftLog: Insert Context-Aware Log"
      },
      {
        "command": "swiftlog.insertStringifiedLog",
        "title": "SwiftLog: Insert JSON.stringify Log"
      },
      {
        "command": "swiftlog.removeAllLogs",
        "title": "SwiftLog: Remove All Logs"
      },
      {
        "command": "swiftlog.removeSpecificLog",
        "title": "SwiftLog: Remove Specific Log"
      }
    ],
    "keybindings": [
      {
        "command": "swiftlog.insertLog",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "swiftlog.insertStringifiedLog",
        "key": "ctrl+alt+j",
        "mac": "cmd+alt+j",
        "when": "editorTextFocus"
      },
      {
        "command": "swiftlog.removeAllLogs",
        "key": "ctrl+shift+alt+d",
        "mac": "cmd+shift+alt+d",
        "when": "editorTextFocus"
      },
      {
        "command": "swiftlog.removeSpecificLog",
        "key": "ctrl+shift+alt+x",
        "mac": "cmd+shift+alt+x",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "SwiftLog",
      "properties": {
        "swiftlog.clientEmoji": {
          "type": "string",
          "default": "🎨",
          "description": "Emoji prefix to use for Client Components"
        },
        "swiftlog.serverEmoji": {
          "type": "string",
          "default": "🎒",
          "description": "Emoji prefix to use for Server Components"
        },
        "swiftlog.clientColor": {
          "type": "string",
          "default": "#00adb5",
          "description": "Hex color code to natively style Context-Aware output in browser DevTools"
        },
        "swiftlog.includeLineNumbers": {
          "type": "boolean",
          "default": false,
          "description": "Dynamically append the active line number directly into the injected log signature"
        },
        "swiftlog.prettyPrint": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, wraps object/array variables in JSON.stringify(value, null, 2) to prevent [object Object] output"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "@types/babel__traverse": "^7.20.1",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0"
  }
}